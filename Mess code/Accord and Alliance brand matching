--------------------------------------------\n","# Paste all the code below this line into a *new, single cell* and run it.\n","\n","import pandas as pd\n","import time\n","from geopy.geocoders import Nominatim\n","from geopy.exc import GeocoderTimedOut, GeocoderServiceError\n","from tqdm import tqdm\n","\n","def geocode_missing_addresses(input_file, output_file):\n","    \"\"\"\n","    Loads a CSV, finds rows with missing latitude/longitude but existing addresses,\n","    and imputes them using Nominatim geocoding.\n","    \"\"\"\n","    try:\n","        df = pd.read_csv(input_file)\n","    except FileNotFoundError:\n","        print(f\"Error: Input file not found at {input_file}\")\n","        return\n","\n","    # Initialize the geocoder.\n","    # !! PLEASE CHANGE \"my-geocoding-app\" to your own app name or email !!\n","    geolocator = Nominatim(user_agent=\"my-colab-geocoder-v1\")\n","\n","    # Get the indices of rows that need geocoding\n","    indices_to_geocode = df[\n","        (df['latitude'].isnull()) &\n","        (df['address'].notnull()) &\n","        (df['address'].str.strip() != '')\n","    ].index\n","\n","    print(f\"Found {len(indices_to_geocode)} addresses to geocode.\")\n","\n","    # Loop through the indices with a progress bar (using tqdm)\n","    for idx in tqdm(indices_to_geocode, desc=\"Geocoding addresses\"):\n","        address = df.loc[idx, 'address']\n","\n","        try:\n","            # Make the geocoding request\n","            location = geolocator.geocode(address, timeout=10)\n","\n","            if location:\n","                # If a location is found, update the DataFrame\n","                df.loc[idx, 'latitude'] = location.latitude\n","                df.loc[idx, 'longitude'] = location.longitude\n","\n","            # IMPORTANT: Wait 1 second between requests\n","            time.sleep(1)\n","\n","        except (GeocoderTimedOut, GeocoderServiceError) as e:\n","            print(f\"Error geocoding address '{address}': {e}. Skipping.\")\n","            time.sleep(1) # Still sleep even if there's an error\n","        except Exception as e:\n","            print(f\"An unexpected error occurred for address '{address}': {e}\")\n","            time.sleep(1)\n","\n","    # Save the updated DataFrame to a new CSV file\n","    df.to_csv(output_file, index=False)\n","    print(f\"\\nGeocoding complete. Data saved to {output_file}\")\n","\n","# --- Run the function ---\n","# This part MUST be in the same cell as the function definition above\n","if __name__ == \"__main__\":\n","\n","    # --- I have added your Colab paths here ---\n","    my_input_path = \"/content/bangladesh_factories_enhanced_20251016_215420.csv\"\n","    my_output_path = \"/content/bangladesh_factories_geocoded.csv\"\n","\n","    print(f\"Starting geocoding for: {my_input_path}\")\n","\n","    geocode_missing_addresses(\n","        input_file=my_input_path,\n","        output_file=my_output_path\n","    )"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"61bNB0YmeYi9","executionInfo":{"status":"ok","timestamp":1760713007015,"user_tz":240,"elapsed":450004,"user":{"displayName":"Alina Malkova","userId":"14263996448341576518"}},"outputId":"f7b31f5b-d9d6-4cf9-f2af-6f0d3be9760b"},"execution_count":null,"outputs":[{"metadata":{"tags":null},"name":"stdout","output_type":"stream","text":["Requirement already satisfied: geopy in /usr/local/lib/python3.12/dist-packages (2.4.1)\n","Requirement already satisfied: tqdm in /usr/local/lib/python3.12/dist-packages (4.67.1)\n","Requirement already satisfied: geographiclib<3,>=1.52 in /usr/local/lib/python3.12/dist-packages (from geopy) (2.1)\n","Starting geocoding for: /content/bangladesh_factories_enhanced_20251016_215420.csv\n","Found 1724 addresses to geocode.\n"]},{"output_type":"stream","name":"stderr","text":["Geocoding addresses: 100%|██████████| 1724/1724 [41:57<00:00,  1.46s/it]"]},{"output_type":"stream","name":"stdout","text":["\n","Geocoding complete. Data sa