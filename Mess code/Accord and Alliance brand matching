{"cells":[{"cell_type":"code","source":["#STEP 1\n","\n","import pandas as pd\n","import pdfplumber\n","import re\n","from geopy.geocoders import Nominatim\n","from geopy.extra.rate_limiter import RateLimiter\n","import time\n","import logging\n","from typing import Dict, List, Tuple, Optional\n","import json\n","from difflib import SequenceMatcher\n","import openpyxl\n","import os\n","\n","# Set up logging\n","logging.basicConfig(level=logging.INFO, format='%(asctime)s - %(levelname)s - %(message)s')\n","logger = logging.getLogger(__name__)\n","\n","class ComprehensiveFactoryExtractor:\n","    def __init__(self, base_path: str = '/content'):\n","        \"\"\"Initialize with base path for all files\"\"\"\n","        self.base_path = base_path\n","\n","        # Initialize geocoder with rate limiting\n","        self.geolocator = Nominatim(user_agent=\"bangladesh_factory_geocoder\")\n","        self.geocode = RateLimiter(self.geolocator.geocode, min_delay_seconds=1.5)\n","\n","        # Define all files to process\n","        self.files_to_process = {\n","            # Accord files\n","            'Accord': {\n","                'files': [\n","                    {'path': 'accord_2013.pdf', 'type': 'pdf', 'year': 2013},\n","                    {'path': 'accord_2014.pdf', 'type': 'pdf', 'year': 2014},\n","                    {'path': 'accord_2016.pdf', 'type': 'pdf', 'year': 2016},\n","                ],\n","                'organization': 'Accord on Fire and Building Safety'\n","            },\n","\n","            # Alliance files\n","            'Alliance': {\n","                'files': [\n","                    {'path': 'alliance_2014.pdf', 'type': 'pdf', 'year': 2014},\n","                    {'path': 'alliance_2015.pdf', 'type': 'pdf', 'year': 2015},\n","                    {'path': 'alliance_2016.pdf', 'type': 'pdf', 'year': 2016},\n","                    {'path': 'alliance_2017.pdf', 'type': 'pdf', 'year': 2017},\n","                    {'path': 'alliance_2018.pdf', 'type': 'pdf', 'year': 2018},\n","                ],\n","                'organization': 'Alliance for Bangladesh Worker Safety'\n","            },\n","\n","            # Brand-specific files\n","            'H&M': {\n","                'files': [\n","                    {'path': 'hm.xlsx', 'type': 'excel', 'year': 2025}\n","                ],\n","                'variations': ['h&m', 'h & m', 'hennes & mauritz', 'hm', 'hennes']\n","            },\n","\n","            'C&A': {\n","                'files': [\n","                    {'path': 'ca.xlsx', 'type': 'excel', 'year': None}\n","                ],\n","                'variations': ['c&a', 'c & a', 'c and a']\n","            },\n","\n","            'Primark': {\n","                'files': [\n","                    {'path': 'primark.pdf', 'type': 'pdf', 'year': None},\n","                    {'path': 'primark2.pdf', 'type': 'pdf', 'year': None}\n","                ],\n","                'variations': ['primark', 'penneys', 'associated british foods']\n","            },\n","\n","            'Walmart': {\n","                'files': [\n","                    {'path': 'walmart.pdf', 'type': 'pdf', 'year': None}\n","                ],\n","                'variations': ['walmart', 'wal-mart', 'wal mart', 'george', 'asda']\n","            },\n","\n","            'Tesco': {\n","                'files': [\n","                    {'path': 'tesco.pdf', 'type': 'pdf', 'year': None}\n","                ],\n","                'variations': ['tesco', 'f&f', 'f & f']\n","            }\n","        }\n","\n","        # General facility files\n","        self.general_files = [\n","            {'path': 'Facilities Bangladesh.xlsx', 'type': 'excel'},\n","            {'path': 'Facilities.xlsx', 'type': 'excel'}\n","        ]\n","\n","        # Store all data\n","        self.all_factories = []\n","        self.brand_factory_mapping = {}\n","        self.accord_alliance_factories = {}\n","        self.geocode_cache = {}\n","\n","    def normalize_address(self, address: str) -> str:\n","        \"\"\"Normalize address for comparison\"\"\"\n","        if not address:\n","            return \"\"\n","\n","        normalized = ' '.join(str(address).lower().strip().split())\n","\n","        replacements = {\n","            'road': 'rd',\n","            'street': 'st',\n","            'avenue': 'ave',\n","            'building': 'bldg',\n","            'plot#': 'plot',\n","            'plot #': 'plot',\n","            'p.o.': 'po',\n","            'p.s.': 'ps',\n","            ',': ' ',\n","            '.': ' ',\n","            '-': ' ',\n","            '/': ' ',\n","            '#': '',\n","            '(': ' ',\n","            ')': ' ',\n","        }\n","\n","        for old, new in replacements.items():\n","            normalized = normalized.replace(old, new)\n","\n","        return ' '.join(normalized.split())\n","\n","    def calculate_address_similarity(self, addr1: str, addr2: str) -> float:\n","        \"\"\"Calculate similarity between two addresses\"\"\"\n","        norm1 = self.normalize_address(addr1)\n","        norm2 = self.normalize_address(addr2)\n","\n","        if not norm1 or not norm2:\n","            return 0.0\n","\n","        # Check for key location matches\n","        key_locations = ['dhaka', 'savar', 'gazipur', 'chittagong', 'narayanganj', 'ashulia', 'mirpur']\n","\n","        location_match_boost = 0.0\n","        for location in key_locations:\n","            if location in norm1 and location in norm2:\n","                location_match_boost = 0.1\n","                break\n","\n","        base_similarity = SequenceMatcher(None, norm1, norm2).ratio()\n","        return min(base_similarity + location_match_boost, 1.0)\n","\n","    def extract_from_excel(self, file_path: str, source_name: str = None) -> List[Dict]:\n","        \"\"\"Extract factory data from Excel files\"\"\"\n","        factories = []\n","        full_path = os.path.join(self.base_path, file_path)\n","\n","        if not os.path.exists(full_path):\n","            logger.warning(f\"File not found: {full_path}\")\n","            return factories\n","\n","        try:\n","            df = pd.read_excel(full_path, engine='openpyxl')\n","            logger.info(f\"Reading Excel: {file_path}, Shape: {df.shape}\")\n","\n","            # Column mappings\n","            column_mappings = {\n","                'factory': 'factory_name',\n","                'factory name': 'factory_name',\n","                'supplier name': 'factory_name',\n","                'vendor name': 'factory_name',\n","                'name': 'factory_name',\n","                'company': 'factory_name',\n","                'address': 'address',\n","                'factory address': 'address',\n","                'location': 'address',\n","                'street address': 'address',\n","                'workers': 'num_workers',\n","                'employees': 'num_workers',\n","                'workforce': 'num_workers',\n","                'city': 'city',\n","                'district': 'district',\n","                'country': 'country',\n","                'postal code': 'postal_code',\n","                'postcode': 'postal_code',\n","                'zip': 'postal_code'\n","            }\n","\n","            # Normalize columns\n","            df.columns = [col.lower().strip() for col in df.columns]\n","\n","            for old_col, new_col in column_mappings.items():\n","                if old_col in df.columns:\n","                    df.rename(columns={old_col: new_col}, inplace=True)\n","\n","            # Process rows\n","            for idx, row in df.iterrows():\n","                factory = {}\n","\n","                if 'factory_name' in df.columns and pd.notna(row.get('factory_name')):\n","                    factory['factory_name'] = str(row['factory_name']).strip()\n","\n","                # Build address\n","                address_parts = []\n","                for col in ['address', 'street address']:\n","                    if col in df.columns and pd.notna(row.get(col)):\n","                        address_parts.append(str(row[col]).strip())\n","\n","                for col in ['city', 'district']:\n","                    if col in df.columns and pd.notna(row.get(col)):\n","                        address_parts.append(str(row[col]).strip())\n","                        factory[col] = str(row[col]).strip()\n","\n","                if address_parts:\n","                    factory['address'] = ', '.join(address_parts)\n","\n","                # Add workers if available\n","                if 'num_workers' in df.columns and pd.notna(row.get('num_workers')):\n","                    try:\n","                        factory['num_workers'] = int(float(str(row['num_workers']).replace(',', '')))\n","                    except:\n","                        pass\n","\n","                factory['source'] = source_name or file_path\n","                factory['file'] = file_path\n","\n","                if factory.get('factory_name') or factory.get('address'):\n","                    factories.append(factory)\n","\n","        except Exception as e:\n","            logger.error(f\"Error processing Excel {file_path}: {str(e)}\")\n","\n","        return factories\n","\n","    def extract_from_pdf(self, file_path: str, source_name: str = None) -> List[Dict]:\n","        \"\"\"Extract factory data from PDF files\"\"\"\n","        factories = []\n","        full_path = os.path.join(self.base_path, file_path)\n","\n","        if not os.path.exists(full_path):\n","            logger.warning(f\"File not found: {full_path}\")\n","            return factories\n","\n","        try:\n","            with pdfplumber.open(full_path) as pdf:\n","                logger.info(f\"Reading PDF: {file_path}, Pages: {len(pdf.pages)}\")\n","\n","                for page_num, page in enumerate(pdf.pages):\n","                    # Extract tables\n","                    tables = page.extract_tables()\n","                    if tables:\n","                        for table in tables:\n","                            factories.extend(self.parse_pdf_table(table, source_name or file_path, page_num))\n","\n","                    # Extract text\n","                    text = page.extract_text()\n","                    if text:\n","                        factories.extend(self.parse_pdf_text(text, source_name or file_path, page_num))\n","\n","        except Exception as e:\n","            logger.error(f\"Error processing PDF {file_path}: {str(e)}\")\n","\n","        # Add file reference\n","        for factory in factories:\n","            factory['file'] = file_path\n","\n","        return factories\n","\n","    def parse_pdf_table(self, table: List, source: str, page_num: int) -> List[Dict]:\n","        \"\"\"Parse table data from PDF\"\"\"\n","        factories = []\n","\n","        if not table or len(table) < 2:\n","            return factories\n","\n","        # Find headers\n","        headers = []\n","        for row in table[:3]:\n","            if row and any(cell for cell in row):\n","                headers = [str(cell).lower().strip() if cell else '' for cell in row]\n","                if any('factory' in h or 'name' in h or 'address' in h for h in headers):\n","                    break\n","\n","        if not headers:\n","            return factories\n","\n","        # Process data rows\n","        for row in table[1:]:\n","            if not row or all(not cell for cell in row):\n","                continue\n","\n","            factory = {'source': source, 'page': page_num + 1}\n","\n","            for i, cell in enumerate(row):\n","                if i < len(headers) and cell:\n","                    header = headers[i]\n","                    cell_value = str(cell).strip()\n","\n","                    if any(x in header for x in ['factory', 'name', 'supplier', 'vendor', 'company']):\n","                        factory['factory_name'] = cell_value\n","                    elif 'address' in header or 'location' in header:\n","                        factory['address'] = cell_value\n","                    elif 'district' in header:\n","                        factory['district'] = cell_value\n","                    elif 'worker' in header or 'employee' in header:\n","                        try:\n","                            factory['num_workers'] = int(re.sub(r'[^\\d]', '', cell_value))\n","                        except:\n","                            pass\n","                    elif 'status' in header:\n","                        factory['status'] = cell_value\n","\n","            if factory.get('factory_name') or factory.get('address'):\n","                factories.append(factory)\n","\n","        return factories\n","\n","    def parse_pdf_text(self, text: str, source: str, page_num: int) -> List[Dict]:\n","        \"\"\"Parse unstructured text from PDF\"\"\"\n","        factories = []\n","        lines = text.split('\\n')\n","\n","        current_factory = None\n","        factory_indicators = ['LTD', 'LIMITED', 'PVT', 'PRIVATE', 'CO.', 'CORP', 'INC',\n","                             'FACTORY', 'GARMENT', 'TEXTILE', 'APPAREL', 'SWEATER', 'KNIT']\n","\n","        for line in lines:\n","            line = line.strip()\n","            if not line or 'FACTORY NAME' in line.upper() or 'FACTORY ADDRESS' in line.upper():\n","                continue\n","\n","            # Check for factory name\n","            if any(indicator in line.upper() for indicator in factory_indicators):\n","                if current_factory and current_factory.get('address'):\n","                    factories.append(current_factory)\n","\n","                current_factory = {\n","                    'factory_name': line,\n","                    'source': source,\n","                    'page': page_num + 1\n","                }\n","            elif current_factory and not current_factory.get('address'):\n","                # Check if this looks like an address\n","                if any(loc in line.lower() for loc in ['dhaka', 'chittagong', 'gazipur', 'savar',\n","                                                        'narayanganj', 'ashulia', 'bangladesh']):\n","                    current_factory['address'] = line\n","\n","        # Add last factory\n","        if current_factory and current_factory.get('address'):\n","            factories.append(current_factory)\n","\n","        return factories\n","\n","    def process_all_files(self):\n","        \"\"\"Process all files in the defined structure\"\"\"\n","\n","        # Process Accord and Alliance files\n","        for org_name in ['Accord', 'Alliance']:\n","            if org_name in self.files_to_process:\n","                org_data = self.files_to_process[org_name]\n","                logger.info(f\"\\n{'='*50}\")\n","                logger.info(f\"Processing {org_name} files\")\n","                logger.info(f\"{'='*50}\")\n","\n","                org_factories = []\n","                for file_info in org_data['files']:\n","                    file_path = file_info['path']\n","                    file_type = file_info['type']\n","                    year = file_info.get('year')\n","\n","                    source_name = f\"{org_name} {year}\" if year else org_name\n","\n","                    if file_type == 'pdf':\n","                        factories = self.extract_from_pdf(file_path, source_name)\n","                    elif file_type == 'excel':\n","                        factories = self.extract_from_excel(file_path, source_name)\n","                    else:\n","                        continue\n","\n","                    # Add organization and year info\n","                    for factory in factories:\n","                        factory['organization'] = org_data.get('organization', org_name)\n","                        if year:\n","                            factory['year'] = year\n","\n","                    org_factories.extend(factories)\n","                    logger.info(f\"  {file_path}: {len(factories)} factories\")\n","\n","                self.accord_alliance_factories[org_name] = org_factories\n","                self.all_factories.extend(org_factories)\n","\n","        # Process brand files\n","        brand_names = [name for name in self.files_to_process.keys()\n","                      if name not in ['Accord', 'Alliance']]\n","\n","        for brand in brand_names:\n","            brand_data = self.files_to_process[brand]\n","            logger.info(f\"\\n{'='*50}\")\n","            logger.info(f\"Processing {brand} files\")\n","            logger.info(f\"{'='*50}\")\n","\n","            brand_factories = []\n","            for file_info in brand_data['files']:\n","                file_path = file_info['path']\n","                file_type = file_info['type']\n","\n","                if file_type == 'pdf':\n","                    factories = self.extract_from_pdf(file_path, brand)\n","                elif file_type == 'excel':\n","                    factories = self.extract_from_excel(file_path, brand)\n","                else:\n","                    continue\n","\n","                # Add brand tag\n","                for factory in factories:\n","                    factory['brand'] = brand\n","\n","                brand_factories.extend(factories)\n","                logger.info(f\"  {file_path}: {len(factories)} factories\")\n","\n","            self.brand_factory_mapping[brand] = brand_factories\n","            self.all_factories.extend(brand_factories)\n","\n","        # Process general facility files\n","        logger.info(f\"\\n{'='*50}\")\n","        logger.info(\"Processing general facility files\")\n","        logger.info(f\"{'='*50}\")\n","\n","        for file_info in self.general_files:\n","            file_path = file_info['path']\n","            file_type = file_info['type']\n","\n","            if file_type == 'excel':\n","                factories = self.extract_from_excel(file_path, \"General Facilities\")\n","            elif file_type == 'pdf':\n","                factories = self.extract_from_pdf(file_path, \"General Facilities\")\n","            else:\n","                continue\n","\n","            self.all_factories.extend(factories)\n","            logger.info(f\"  {file_path}: {len(factories)} factories\")\n","\n","    def match_factories_across_sources(self):\n","        \"\"\"Match factories across different sources to identify shared suppliers\"\"\"\n","        logger.info(\"\\nMatching factories across sources...\")\n","\n","        for i, factory in enumerate(self.all_factories):\n","            matched_sources = []\n","            matched_brands = []\n","\n","            factory_address = factory.get('address', '')\n","            factory_name = factory.get('factory_name', '')\n","\n","            if not factory_address and not factory_name:\n","                continue\n","\n","            # Compare with brand factories\n","            for brand, brand_factories in self.brand_factory_mapping.items():\n","                for bf in brand_factories:\n","                    if bf is factory:  # Skip self\n","                        continue\n","\n","                    # Check address similarity\n","                    if factory_address and bf.get('address'):\n","                        addr_similarity = self.calculate_address_similarity(\n","                            factory_address, bf['address']\n","                        )\n","                        if addr_similarity > 0.75:\n","                            matched_brands.append(brand)\n","                            break\n","\n","                    # Check name similarity\n","                    if factory_name and bf.get('factory_name'):\n","                        name_similarity = SequenceMatcher(\n","                            None,\n","                            factory_name.lower(),\n","                            bf['factory_name'].lower()\n","                        ).ratio()\n","                        if name_similarity > 0.85:\n","                            matched_brands.append(brand)\n","                            break\n","\n","            # Add matched brands\n","            if matched_brands:\n","                existing_brand = factory.get('brand', '')\n","                all_brands = list(set([existing_brand] + matched_brands)) if existing_brand else matched_brands\n","                factory['matched_brands'] = ', '.join(filter(None, all_brands))\n","\n","    def geocode_address_with_cache(self, address: str, district: str = '') -> Tuple[Optional[float], Optional[float]]:\n","        \"\"\"Geocode address with caching\"\"\"\n","        cache_key = f\"{address}|{district}\".lower()\n","\n","        if cache_key in self.geocode_cache:\n","            return self.geocode_cache[cache_key]\n","\n","        full_address = address\n","        if district and district not in address:\n","            full_address += f\", {district}\"\n","        full_address += \", Bangladesh\"\n","\n","        try:\n","            location = self.geocode(full_address)\n","            if location:\n","                result = (location.latitude, location.longitude)\n","                self.geocode_cache[cache_key] = result\n","                return result\n","        except Exception as e:\n","            logger.warning(f\"Geocoding failed: {str(e)}\")\n","\n","        self.geocode_cache[cache_key] = (None, None)\n","        return None, None\n","\n","    def add_geocoding(self, sample_only: bool = False):\n","        \"\"\"Add geocoding to factories\"\"\"\n","        logger.info(\"\\nAdding geocoding...\")\n","\n","        factories_to_geocode = self.all_factories[:50] if sample_only else self.all_factories\n","\n","        for factory in factories_to_geocode:\n","            if factory.get('address'):\n","                lat, lon = self.geocode_address_with_cache(\n","                    factory.get('address', ''),\n","                    factory.get('district', '')\n","                )\n","                factory['latitude'] = lat\n","                factory['longitude'] = lon\n","                factory['geocoded'] = 'Yes' if lat and lon else 'No'\n","\n","    def save_results(self, output_dir: str = '.'):\n","        \"\"\"Save results to multiple CSV files\"\"\"\n","        if not self.all_factories:\n","            logger.warning(\"No data to save\")\n","            return\n","\n","        # Create main dataframe\n","        df = pd.DataFrame(self.all_factories)\n","\n","        # Remove duplicates\n","        if 'factory_name' in df.columns and 'address' in df.columns:\n","            df.drop_duplicates(subset=['factory_name', 'address'], keep='first', inplace=True)\n","\n","        # Save complete dataset\n","        complete_file = os.path.join(output_dir, 'bangladesh_factories_complete.csv')\n","        df.to_csv(complete_file, index=False, encoding='utf-8')\n","        logger.info(f\"\\nSaved complete dataset: {complete_file} ({len(df)} factories)\")\n","\n","        # Save Accord factories\n","        if 'organization' in df.columns:\n","            accord_df = df[df['organization'].str.contains('Accord', na=False)]\n","            if not accord_df.empty:\n","                accord_file = os.path.join(output_dir, 'accord_factories.csv')\n","                accord_df.to_csv(accord_file, index=False)\n","                logger.info(f\"Saved Accord factories: {accord_file} ({len(accord_df)} factories)\")\n","\n","            # Save Alliance factories\n","            alliance_df = df[df['organization'].str.contains('Alliance', na=False)]\n","            if not alliance_df.empty:\n","                alliance_file = os.path.join(output_dir, 'alliance_factories.csv')\n","                alliance_df.to_csv(alliance_file, index=False)\n","                logger.info(f\"Saved Alliance factories: {alliance_file} ({len(alliance_df)} factories)\")\n","\n","        # Save brand-specific files\n","        if 'brand' in df.columns:\n","            for brand in df['brand'].unique():\n","                if pd.notna(brand):\n","                    brand_df = df[df['brand'] == brand]\n","                    brand_file = os.path.join(output_dir, f\"{brand.lower().replace(' ', '_')}_factories.csv\")\n","                    brand_df.to_csv(brand_file, index=False)\n","                    logger.info(f\"Saved {brand} factories: {brand_file} ({len(brand_df)} factories)\")\n","\n","        # Print summary\n","        print(\"\\n\" + \"=\"*60)\n","        print(\"EXTRACTION SUMMARY\")\n","        print(\"=\"*60)\n","        print(f\"Total unique factories: {len(df)}\")\n","\n","        if 'source' in df.columns:\n","            print(\"\\nFactories by source:\")\n","            print(df['source'].value_counts().head(10))\n","\n","        if 'brand' in df.columns:\n","            print(\"\\nFactories by brand:\")\n","            print(df['brand'].value_counts())\n","\n","        if 'year' in df.columns:\n","            print(\"\\nFactories by year:\")\n","            print(df['year'].value_counts().sort_index())\n","\n","        if 'geocoded' in df.columns:\n","            geocoded = (df['geocoded'] == 'Yes').sum()\n","            print(f\"\\nGeocoding: {geocoded}/{len(df)} successfully geocoded\")\n","\n","        return df\n","\n","    def run(self, geocode: bool = True, sample_geocoding: bool = False):\n","        \"\"\"Main execution method\"\"\"\n","        print(\"\\n\" + \"=\"*60)\n","        print(\"BANGLADESH FACTORY DATA EXTRACTION\")\n","        print(\"=\"*60)\n","\n","        # Process all files\n","        self.process_all_files()\n","\n","        # Match factories across sources\n","        self.match_factories_across_sources()\n","\n","        # Add geocoding if requested\n","        if geocode:\n","            self.add_geocoding(sample_only=sample_geocoding)\n","\n","        # Save results\n","        df = self.save_results()\n","\n","        print(\"\\n\" + \"=\"*60)\n","        print(\"PROCESSING COMPLETE!\")\n","        print(\"=\"*60)\n","\n","        return df\n","\n","# Main execution\n","if __name__ == \"__main__\":\n","    # Initialize extractor\n","    extractor = ComprehensiveFactoryExtractor(base_path='/content')\n","\n","    # Run extraction\n","    # Set geocode=False for faster testing\n","    # Set sample_geocoding=True to only geocode first 50 factories\n","    df = extractor.run(geocode=True, sample_geocoding=False)\n","\n","    print(\"\\nAll files have been processed and saved!\")\n","    print(\"Check the output directory for CSV files\")"],"metadata":{"id":"qc0gM5f7yz9m"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["#STEP 3\n","\n","\n","import pandas as pd\n","import re\n","from collections import Counter\n","from datetime import datetime\n","from fuzzywuzzy import fuzz\n","import json\n","import numpy as np # Import numpy\n","\n","class EnhancedBrandMatcher:\n","    \"\"\"Enhance existing factory data with improved brand matching\"\"\"\n","\n","    def __init__(self, input_csv='bangladesh_factories_complete.csv'):\n","        \"\"\"Initialize with existing CSV file\"\"\"\n","        self.input_csv = input_csv\n","        self.df = None\n","\n","        # Initialize comprehensive brand database from first algorithm\n","        self.brand_database = self.load_brand_database()\n","\n","        # Initialize statistics\n","        self.stats = {\n","            'original_brands': 0,\n","            'new_matches': 0,\n","            'enhanced_matches': 0,\n","            'total_brands_found': 0\n","        }\n","\n","    def load_brand_database(self):\n","        \"\"\"Comprehensive brand database with variations and codes\"\"\"\n","        return {\n","            'H&M': {\n","                'variations': ['h&m', 'h & m', 'hennes & mauritz', 'hennes and mauritz', 'hm', 'h and m'],\n","                'codes': ['hm', 'hen', 'mau', 'hnm'],\n","            },\n","            'Zara': {\n","                'variations': ['zara', 'inditex', 'zara home', 'massimo dutti', 'pull & bear', 'pull and bear', 'bershka', 'stradivarius', 'oysho'],\n","                'codes': ['zar', 'ind', 'itx', 'zra', 'msd', 'pab', 'brk'],\n","            },\n","            'Primark': {\n","                'variations': ['primark', 'penneys', 'primark stores', 'associated british foods', 'abf'],\n","                'codes': ['pri', 'pen', 'pmk', 'prm', 'abf'],\n","            },\n","            'Walmart': {\n","                'variations': ['walmart', 'wal-mart', 'wal mart', 'george', 'george at asda', 'asda', 'sams club'],\n","                'codes': ['wmt', 'wal', 'geo', 'wlm', 'asd', 'sam'],\n","            },\n","            'Target': {\n","                'variations': ['target', 'target corporation', 'target stores', 'target brands', 'good & gather', 'cat & jack'],\n","                'codes': ['tgt', 'tar', 'trg'],\n","            },\n","            'Gap': {\n","                'variations': ['gap', 'gap inc', 'the gap', 'old navy', 'banana republic', 'athleta', 'intermix'],\n","                'codes': ['gap', 'gps', 'old', 'ban', 'onv', 'ath'],\n","            },\n","            'Uniqlo': {\n","                'variations': ['uniqlo', 'fast retailing', 'gu', 'theory', 'princesse tam tam', 'comptoir des cotonniers'],\n","                'codes': ['uni', 'uql', 'frt', 'unq', 'guu'],\n","            },\n","            'C&A': {\n","                'variations': ['c&a', 'c & a', 'c and a', 'ca', 'c&a europe', 'c&a china'],\n","                'codes': ['cna', 'caa', 'c&a', 'cae'],\n","            },\n","            'Next': {\n","                'variations': ['next', 'next plc', 'next retail', 'next direct', 'next directory'],\n","                'codes': ['nxt', 'nex', 'nxp', 'nxd'],\n","            },\n","            'Forever 21': {\n","                'variations': ['forever 21', 'forever21', 'f21', 'forever xxi', 'xxi', 'forever 21 inc'],\n","                'codes': ['f21', 'for', 'fvr', 'f2a', 'xxi'],\n","            },\n","            'Mango': {\n","                'variations': ['mango', 'mng', 'punto fa', 'mango man', 'violeta', 'he by mango'],\n","                'codes': ['mng', 'man', 'mgo', 'vio'],\n","            },\n","            'Marks & Spencer': {\n","                'variations': ['marks & spencer', 'marks and spencer', 'm&s', 'marks spencer', 'm & s', 'marks', 'spencer'],\n","                'codes': ['m&s', 'mks', 'mns', 'mas'],\n","            },\n","            'Tesco': {\n","                'variations': ['tesco', 'f&f', 'f & f', 'tesco clothing', 'florence & fred', 'florence and fred'],\n","                'codes': ['tsc', 'tco', 'f&f', 'fnf'],\n","            },\n","            'KiK': {\n","                'variations': ['kik', 'kik textilien', 'kik textile', 'kik textil'],\n","                'codes': ['kik', 'ktx', 'kkt'],\n","            },\n","            'Esprit': {\n","                'variations': ['esprit', 'esprit holdings', 'edc', 'edc by esprit'],\n","                'codes': ['esp', 'epr', 'edc', 'esh'],\n","            },\n","            'ASOS': {\n","                'variations': ['asos', 'asos.com', 'asos design', 'asos marketplace', 'asos white', 'asos curve'],\n","                'codes': ['aso', 'ass', 'aos', 'asd'],\n","            },\n","            'Benetton': {\n","                'variations': ['benetton', 'united colors of benetton', 'ucb', 'sisley', 'playlife'],\n","                'codes': ['ben', 'ucb', 'bnt', 'sis'],\n","            },\n","            'VF Corporation': {\n","                'variations': ['vf', 'vf corp', 'vans', 'the north face', 'timberland', 'dickies', 'eastpak', 'jansport', 'napapijri'],\n","                'codes': ['vfc', 'vfp', 'vns', 'tnf', 'tim', 'dck'],\n","            },\n","            'PVH': {\n","                'variations': ['pvh', 'calvin klein', 'tommy hilfiger', 'ck', 'tommy', 'van heusen', 'izod', 'arrow'],\n","                'codes': ['pvh', 'ckl', 'tom', 'vhs', 'izd'],\n","            },\n","            'Nike': {\n","                'variations': ['nike', 'nike inc', 'jordan', 'air jordan', 'converse', 'chuck taylor'],\n","                'codes': ['nke', 'nik', 'jor', 'con'],\n","            },\n","            'Adidas': {\n","                'variations': ['adidas', 'adidas ag', 'reebok', 'three stripes'],\n","                'codes': ['adi', 'ads', 'rbk'],\n","            },\n","            'Puma': {\n","                'variations': ['puma', 'puma se', 'puma ag'],\n","                'codes': ['pum', 'pma'],\n","            },\n","            'Levi\\'s': {\n","                'variations': ['levi', 'levis', 'levi strauss', 'levi\\'s', 'dockers', 'denizen'],\n","                'codes': ['lev', 'lvi', 'lsc', 'doc'],\n","            },\n","            'Decathlon': {\n","                'variations': ['decathlon', 'quechua', 'kalenji', 'domyos', 'kipsta', 'tribord'],\n","                'codes': ['dec', 'dct', 'que', 'kal'],\n","            },\n","            'Lidl': {\n","                'variations': ['lidl', 'esmara', 'livergy', 'pepperts'],\n","                'codes': ['lid', 'ldl', 'esm', 'liv'],\n","            },\n","            'Aldi': {\n","                'variations': ['aldi', 'lily & dan', 'serra', 'crane'],\n","                'codes': ['ald', 'ali', 'lnd'],\n","            },\n","            'JCPenney': {\n","                'variations': ['jcpenney', 'jc penney', 'jcp', 'arizona', 'st johns bay'],\n","                'codes': ['jcp', 'jcn', 'ari', 'sjb'],\n","            },\n","            'Kohl\\'s': {\n","                'variations': ['kohls', 'kohl\\'s', 'sonoma', 'croft & barrow', 'apt 9'],\n","                'codes': ['khl', 'koh', 'son', 'cfb'],\n","            },\n","            'Carrefour': {\n","                'variations': ['carrefour', 'tex'],\n","                'codes': ['crf', 'car', 'tex'],\n","            }\n","        }\n","\n","    def load_data(self):\n","        \"\"\"Load the CSV file\"\"\"\n","        try:\n","            self.df = pd.read_csv(self.input_csv)\n","            print(f\"Loaded {len(self.df)} factories from {self.input_csv}\")\n","\n","            # Count existing brands\n","            if 'brand' in self.df.columns:\n","                self.stats['original_brands'] = self.df['brand'].notna().sum()\n","            if 'matched_brands' in self.df.columns:\n","                self.stats['original_brands'] += self.df['matched_brands'].notna().sum()\n","\n","            return True\n","        except Exception as e:\n","            print(f\"Error loading CSV: {e}\")\n","            return False\n","\n","    def match_brands_advanced(self, row):\n","        \"\"\"Enhanced brand matching using multiple methods\"\"\"\n","        matched_brands = {}\n","\n","        # Combine all searchable text\n","        search_text = ' '.join([\n","            str(row.get('factory_name', '')),\n","            str(row.get('address', '')),\n","            str(row.get('source', '')),\n","            str(row.get('brand', '')),\n","            str(row.get('matched_brands', ''))\n","        ]).lower()\n","\n","        # Also check the file field if it contains brand hints\n","        if pd.notna(row.get('file')):\n","            file_name = str(row['file']).lower()\n","            search_text += ' ' + file_name\n","\n","        for brand, brand_info in self.brand_database.items():\n","            confidence = 0.0\n","            match_source = None\n","\n","            # Method 1: Direct variations match\n","            for variation in brand_info['variations']:\n","                if variation in search_text:\n","                    confidence = max(confidence, 1.0)\n","                    match_source = f\"variation:{variation}\"\n","                    break\n","\n","            # Method 2: Code pattern matching\n","            for code in brand_info['codes']:\n","                # Look for codes with numbers (like HM-123, ZAR_456)\n","                pattern = rf'\\b{code}[-_]?\\d+\\b'\n","                if re.search(pattern, search_text):\n","                    confidence = max(confidence, 0.85)\n","                    if not match_source:\n","                        match_source = f\"code:{code}\"\n","\n","                # Also check for standalone codes\n","                if f' {code} ' in f' {search_text} ':\n","                    confidence = max(confidence, 0.7)\n","                    if not match_source:\n","                        match_source = f\"code:{code}\"\n","\n","            # Method 3: Fuzzy matching on factory name\n","            factory_name = str(row.get('factory_name', '')).lower()\n","            if factory_name and factory_name != 'nan':\n","                for variation in brand_info['variations']:\n","                    try:\n","                        # Partial ratio for substring matches\n","                        ratio = fuzz.partial_ratio(variation, factory_name)\n","                        if ratio > 85:\n","                            confidence = max(confidence, ratio / 100)\n","                            if not match_source:\n","                                match_source = f\"fuzzy:{variation}\"\n","\n","                        # Token set ratio for word order variations\n","                        token_ratio = fuzz.token_set_ratio(variation, factory_name)\n","                        if token_ratio > 90:\n","                            confidence = max(confidence, token_ratio / 100)\n","                            if not match_source:\n","                                match_source = f\"token:{variation}\"\n","                    except:\n","                        pass\n","\n","            # Method 4: Check source field for brand names\n","            source_field = str(row.get('source', '')).lower()\n","            if source_field and source_field != 'nan':\n","                for variation in brand_info['variations']:\n","                    if variation in source_field:\n","                        confidence = max(confidence, 0.9)\n","                        if not match_source:\n","                            match_source = f\"source:{variation}\"\n","\n","            # Method 5: Check if brand is already listed\n","            existing_brand = str(row.get('brand', '')).lower()\n","            existing_matched = str(row.get('matched_brands', '')).lower()\n","\n","            for variation in brand_info['variations']:\n","                if variation in existing_brand or variation in existing_matched:\n","                    confidence = max(confidence, 1.0)\n","                    if not match_source:\n","                        match_source = f\"existing:{variation}\"\n","\n","            # Store match if confidence is sufficient\n","            if confidence > 0.5:\n","                matched_brands[brand] = {\n","                    'confidence': confidence,\n","                    'source': match_source\n","                }\n","\n","        return matched_brands\n","\n","    def classify_brand_tier(self, brands):\n","        \"\"\"Classify brands into tiers\"\"\"\n","        if not brands:\n","            return 'unidentified'\n","\n","        brand_set = set(brands) if isinstance(brands, list) else {brands}\n","\n","        # Premium/Luxury\n","        if brand_set & {'Zara', 'H&M', 'Uniqlo', 'Next', 'Mango', 'Esprit', 'Calvin Klein', 'Tommy Hilfiger'}:\n","            return 'premium_fast_fashion'\n","\n","        # Value fast fashion\n","        elif brand_set & {'Primark', 'Forever 21', 'C&A', 'KiK'}:\n","            return 'value_fast_fashion'\n","\n","        # Mass market retailers\n","        elif brand_set & {'Walmart', 'Target', 'Tesco', 'Carrefour', 'JCPenney', 'Kohl\\'s'}:\n","            return 'mass_market'\n","\n","        # Sportswear\n","        elif brand_set & {'Nike', 'Adidas', 'Puma', 'Decathlon'}:\n","            return 'sportswear'\n","\n","        # Specialty/Other\n","        elif brand_set & {'Gap', 'Levi\\'s', 'VF Corporation', 'PVH', 'ASOS', 'Benetton'}:\n","            return 'specialty_brands'\n","\n","        # Discount retailers\n","        elif brand_set & {'Lidl', 'Aldi'}:\n","            return 'discount_retailers'\n","\n","        else:\n","            return 'other_brands'\n","\n","    def enhance_factory_data(self):\n","        \"\"\"Main function to enhance all factory data\"\"\"\n","        print(\"\\n\" + \"=\"*60)\n","        print(\"ENHANCING FACTORY DATA WITH ADVANCED BRAND MATCHING\")\n","        print(\"=\"*60)\n","\n","        # Initialize new columns\n","        self.df['identified_brands'] = None\n","        self.df['brand_confidence'] = None\n","        self.df['num_brands'] = 0\n","        self.df['primary_brand'] = None\n","        self.df['max_confidence'] = 0\n","        self.df['brand_tier'] = 'unidentified'\n","        self.df['match_sources'] = None\n","\n","        print(\"\\n🔍 Processing factories...\")\n","\n","        for idx, row in self.df.iterrows():\n","            # Get brand matches\n","            brands = self.match_brands_advanced(row)\n","\n","            if brands:\n","                # Sort by confidence\n","                sorted_brands = sorted(brands.items(), key=lambda x: x[1]['confidence'], reverse=True)\n","\n","                # Extract data\n","                brand_names = [b[0] for b in sorted_brands]\n","                confidences = [b[1]['confidence'] for b in sorted_brands]\n","                sources = [b[1]['source'] for b in sorted_brands]\n","\n","                # Update dataframe\n","                self.df.at[idx, 'identified_brands'] = brand_names\n","                self.df.at[idx, 'brand_confidence'] = confidences\n","                self.df.at[idx, 'num_brands'] = len(brands)\n","                self.df.at[idx, 'primary_brand'] = brand_names[0]\n","                self.df.at[idx, 'max_confidence'] = confidences[0]\n","                self.df.at[idx, 'brand_tier'] = self.classify_brand_tier(brand_names)\n","                self.df.at[idx, 'match_sources'] = sources\n","\n","                self.stats['new_matches'] += 1\n","\n","            # Progress indicator\n","            if (idx + 1) % 100 == 0:\n","                print(f\"  Processed {idx + 1}/{len(self.df)} factories...\")\n","\n","        # Calculate statistics\n","        self.stats['enhanced_matches'] = self.df['num_brands'].gt(0).sum()\n","        self.stats['total_brands_found'] = self.df['num_brands'].sum()\n","\n","        print(f\"✓ Processing complete!\")\n","\n","    def generate_summary_statistics(self):\n","        \"\"\"Generate and print summary statistics\"\"\"\n","        print(\"\\n\" + \"=\"*60)\n","        print(\"📊 ENHANCEMENT SUMMARY\")\n","        print(\"=\"*60)\n","\n","        print(f\"\\n📈 Overall Statistics:\")\n","        print(f\"  • Total factories: {len(self.df)}\")\n","        print(f\"  • Originally had brands: {self.stats['original_brands']}\")\n","        print(f\"  • Now have brands: {self.stats['enhanced_matches']}\")\n","        print(f\"  • New matches found: {self.stats['enhanced_matches'] - self.stats['original_brands']}\")\n","        print(f\"  • Total brand connections: {self.stats['total_brands_found']}\")\n","\n","        # Brand frequency\n","        all_brands = []\n","        for brands_list in self.df['identified_brands'].dropna():\n","            if brands_list:\n","                all_brands.extend(brands_list)\n","\n","        brand_counts = Counter(all_brands)\n","\n","        print(f\"\\n🏷️ Top Brands by Factory Count:\")\n","        for brand, count in brand_counts.most_common(15):\n","            pct = (count / len(self.df)) * 100\n","            print(f\"  • {brand}: {count} factories ({pct:.1f}%)\")\n","\n","        # Tier distribution\n","        print(f\"\\n📊 Brand Tier Distribution:\")\n","        tier_counts = self.df['brand_tier'].value_counts()\n","        for tier, count in tier_counts.items():\n","            pct = (count / len(self.df)) * 100\n","            print(f\"  • {tier.replace('_', ' ').title()}: {count} factories ({pct:.1f}%)\")\n","\n","        # Confidence distribution\n","        print(f\"\\n🎯 Match Confidence Distribution:\")\n","        high_conf = (self.df['max_confidence'] >= 0.9).sum()\n","        medium_conf = ((self.df['max_confidence'] >= 0.7) & (self.df['max_confidence'] < 0.9)).sum()\n","        low_conf = ((self.df['max_confidence'] > 0) & (self.df['max_confidence'] < 0.7)).sum()\n","\n","        print(f\"  • High (≥90%): {high_conf} factories\")\n","        print(f\"  • Medium (70-89%): {medium_conf} factories\")\n","        print(f\"  • Low (<70%): {low_conf} factories\")\n","\n","        # Multi-brand factories\n","        multi_brand = self.df[self.df['num_brands'] > 1]\n","        if len(multi_brand) > 0:\n","            print(f\"\\n🏭 Multi-Brand Factories:\")\n","            print(f\"  • Factories with multiple brands: {len(multi_brand)}\")\n","            print(f\"  • Average brands per multi-brand factory: {multi_brand['num_brands'].mean():.1f}\")\n","            print(f\"  • Maximum brands in one factory: {multi_brand['num_brands'].max()}\")\n","\n","        # Source analysis\n","        if 'source' in self.df.columns:\n","            print(f\"\\n📁 Brand Matches by Source:\")\n","            for source in self.df['source'].dropna().unique()[:10]:\n","                source_df = self.df[self.df['source'] == source]\n","                matched = source_df['num_brands'].gt(0).sum()\n","                total = len(source_df)\n","                if total > 0:\n","                    pct = (matched / total) * 100\n","                    print(f\"  • {source}: {matched}/{total} ({pct:.1f}%)\")\n","\n","    def save_enhanced_data(self):\n","        \"\"\"Save the enhanced data to files\"\"\"\n","        timestamp = datetime.now().strftime(\"%Y%m%d_%H%M%S\")\n","\n","        # Save main enhanced file\n","        output_file = f'bangladesh_factories_enhanced_{timestamp}.csv'\n","        self.df.to_csv(output_file, index=False)\n","        print(f\"\\n💾 Saved enhanced dataset: {output_file}\")\n","\n","        # Save brand-matched factories only\n","        brand_df = self.df[self.df['num_brands'] > 0].copy()\n","        brand_file = f'bangladesh_brand_factories_{timestamp}.csv'\n","        brand_df.to_csv(brand_file, index=False)\n","        print(f\"💾 Saved brand factories: {brand_file} ({len(brand_df)} factories)\")\n","\n","        # Create detailed JSON report\n","        report_data = {\n","            'timestamp': datetime.now().isoformat(),\n","            'statistics': {k: (v.item() if isinstance(v, np.int64) else v) for k, v in self.stats.items()}, # Convert np.int64\n","            'brand_counts': dict(Counter(brand for brands in self.df['identified_brands'].dropna()\n","                                       for brand in brands).most_common()),\n","            'tier_distribution': self.df['brand_tier'].value_counts().apply(lambda x: x.item() if isinstance(x, np.int64) else x).to_dict(), # Convert np.int64\n","            'confidence_stats': {\n","                'high': int((self.df['max_confidence'] >= 0.9).sum()),\n","                'medium': int(((self.df['max_confidence'] >= 0.7) & (self.df['max_confidence'] < 0.9)).sum()),\n","                'low': int(((self.df['max_confidence'] > 0) & (self.df['max_confidence'] < 0.7)).sum())\n","            }\n","        }\n","\n","        report_file = f'enhancement_report_{timestamp}.json'\n","        with open(report_file, 'w') as f:\n","            json.dump(report_data, f, indent=2)\n","        print(f\"💾 Saved detailed report: {report_file}\")\n","\n","        return output_file, brand_file, report_file\n","\n","    def run(self):\n","        \"\"\"Main execution method\"\"\"\n","        # Load data\n","        if not self.load_data():\n","            return None\n","\n","        # Enhance with brand matching\n","        self.enhance_factory_data()\n","\n","        # Generate statistics\n","        self.generate_summary_statistics()\n","\n","        # Save results\n","        files = self.save_enhanced_data()\n","\n","        print(\"\\n\" + \"=\"*60)\n","        print(\"✅ ENHANCEMENT COMPLETE!\")\n","        print(\"=\"*60)\n","        print(f\"Enhanced {self.stats['enhanced_matches'] - self.stats['original_brands']} additional factories with brand data\")\n","\n","        return self.df, files\n","\n","# Main execution\n","if __name__ == \"__main__\":\n","    # Initialize the enhancer with your CSV file\n","    enhancer = EnhancedBrandMatcher('bangladesh_factories_complete.csv')\n","\n","    # Run the enhancement\n","    enhanced_df, output_files = enhancer.run()\n","\n","    if enhanced_df is not None:\n","        print(\"\\n🎉 Success! Check the output files for enhanced data.\")\n","        print(\"The main enhanced file contains all original data plus:\")\n","        print(\"  - identified_brands: List of matched brands\")\n","        print(\"  - brand_confidence: Confidence scores for each match\")\n","        print(\"  - primary_brand: The highest confidence brand\")\n","        print(\"  - brand_tier: Classification of brand market segment\")\n","        print(\"  - match_sources: How each brand was matched\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"RJFjXY45Ad1J","executionInfo":{"status":"ok","timestamp":1760651660261,"user_tz":240,"elapsed":13739,"user":{"displayName":"Alina Malkova","userId":"14263996448341576518"}},"outputId":"d75ef21e-536b-4692-8b2e-8ec87f885b1e"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Loaded 2870 factories from bangladesh_factories_complete.csv\n","\n","============================================================\n","ENHANCING FACTORY DATA WITH ADVANCED BRAND MATCHING\n","=========================================