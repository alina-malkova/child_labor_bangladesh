MISSING', 'NA', 'na', 'N/A', 'n/a',\n","                               'None', 'none', 'NULL', 'null', '.', '..', '...',\n","                               'Not applicable', 'Unknown', 'DK', \"Don't know\", 'Refused']\n","\n","    for col in df_fixed.columns:\n","        if df_fixed[col].dtype == 'object':\n","            # Check for string missing values\n","            mask_missing = df_fixed[col].isin(string_missing_patterns)\n","            count_missing = mask_missing.sum()\n","\n","            if count_missing > 0:\n","                print(f\"   {col}: Found {count_missing} string missing values\")\n","                # Replace with proper NaN\n","                df_fixed.loc[mask_missing, col] = np.nan\n","                issues_found.append(f\"{col}: {count_missing} string missing values\")\n","                fixes_applied.append(f\"Converted {count_missing} string missing to NaN in {col}\")\n","\n","    # ============================================================\n","    # 2. CHECK NUMERIC COLUMNS WITH OBJECT DTYPE\n","    # ============================================================\n","    print(\"\\n2. CHECKING FOR NUMERIC COLUMNS STORED AS STRINGS\")\n","\n","    numeric_columns = ['age', 'wealth', 'hhsize', 'edyears', 'latitude', 'longitude',\n","                       'nearest_factory_km', 'dist_to_dhaka_km', 'year']\n","\n","    for col in numeric_columns:\n","        if col in df_fixed.columns:\n","            if df_fixed[col].dtype == 'object':\n","                print(f\"   {col} is stored as object, converting to numeric...\")\n","\n","                # First replace string missing values\n","                df_fixed[col] = df_fixed[col].replace(string_missing_patterns, np.nan)\n","\n","                # Then convert to numeric\n","                before_count = len(df_fixed)\n","                df_fixed[col] = pd.to_numeric(df_fixed[col], errors='coerce')\n","                after_null = df_fixed[col].isnull().sum()\n","\n","                if after_null > before_count * 0.1:\n","                    print(f\"     Warning: {after_null} values couldn't be converted to numeric\")\n","                    issues_found.append(f\"{col}: {after_null} non-numeric values\")\n","\n","                fixes_applied.append(f\"Converted {col} to numeric\")\n","\n","    # ============================================================\n","    # 3. CHECK BINARY VARIABLES\n","    # ============================================================\n","    print(\"\\n3. CHECKING BINARY VARIABLES\")\n","\n","    binary_vars = ['child_labor', 'within_10km', 'post_rana', 'is_working', 'is_child']\n","\n","    for var in binary_vars:\n","        if var in df_fixed.columns:\n","            unique_vals = df_fixed[var].dropna().unique()\n","\n","            # Check if it's properly binary\n","            if df_fixed[var].dtype == 'object':\n","                print(f\"   {var} is object type with values: {unique_vals[:5]}\")\n","\n","                # Map common binary representations\n","                binary_mapping = {\n","                    'Yes': 1, 'yes': 1, 'YES': 1, 'Y': 1, 'y': 1, '1': 1, 1.0: 1, True: 1,\n","                    'No': 0, 'no': 0, 'NO': 0, 'N': 0, 'n': 0, '0': 0, 0.0: 0, False: 0\n","                }\n","\n","                df_fixed[var] = df_fixed[var].map(lambda x: binary_mapping.get(x, np.nan))\n","                fixes_applied.append(f\"Converted {var} to binary 0/1\")\n","\n","            elif not set(unique_vals).issubset({0, 1, 0.0, 1.0}):\n","                print(f\"   {var} has non-binary values: {unique_vals}\")\n","                issues_found.append(f\"{var} has non-binary values\")\n","\n","    # ============================================================\n","    # 4. CHECK FOR INFINITE VALUES\n","    # ============================================================\n","    print(\"\\n4. CHECKING FOR INFINITE VALUES\")\n","\n","    numeric_cols = df_fixed.select_dtypes(include=[np.number]).columns\n","\n","    for col in numeric_cols:\n","        inf_count = np.isinf(df_fixed[col]).sum()\n","        if inf_count > 0:\n","            print(f\"   {col}: Found {inf_count} infinite values\")\n","            df_fixed[col] = df_fixed[col].replace([np.inf, -np.inf], np.nan)\n","            issues_found.append(f\"{col}: {inf_count} infinite values\")\n","            fixes_applied.append(f\"Replaced {inf_count} infinite values with NaN in {col}\")\n","\n","    # ============================================================\n","    # 5. CHECK PANEL STRUCTURE\n","    # ============================================================\n","    print(\"\\n5. CHECKING PANEL STRUCTURE\")\n","\n","    if 'individual_id' in df_fixed.columns and 'year' in df_fixed.columns:\n","        # Check for duplicates\n","        duplicates = df_fixed.duplicated(subset=['individual_id', 'year']).sum()\n","        if duplicates > 0:\n","            print(f\"   Found {duplicates} duplicate individual-year observations\")\n","            df_fixed = df_fixed.drop_duplicates(subset=['individual_id', 'year'])\n","            issues_found.append(f\"{duplicates} duplicate observations\")\n","            fixes_applied.append(f\"Removed {duplicates} duplicates\")\n","\n","        # Check panel balance\n","        panel_balance = df_fixed.groupby('individual_id')['year'].count()\n","        print(f\"   Panel balance: min={panel_balance.min()}, max={panel_balance.max()}, \"\n","              f\"mean={panel_balance.mean():.2f}\")\n","\n","    # ============================================================\n","    # 6. REPORT MISSING DATA PATTERNS\n","    # ============================================================\n","    print(\"\\n6. MISSING DATA PATTERNS AFTER FIXES\")\n","\n","    missing_report = []\n","    for col in df_fixed.columns:\n","        missing_count = df_fixed[col].isnull().sum()\n","        missing_pct = 100 * missing_count / len(df_fixed)\n","\n","        if missing_pct > 0:\n","    