ing education composite...\")\n","        df_imputed['education_composite'] = df_imputed['edyears']\n","\n","        edlevel_to_years = {\n","            0: 0,   # No education\n","            1: 5,   # Primary\n","            2: 8,   # Secondary\n","            3: 12,  # Higher\n","            4: 16   # Higher/University\n","        }\n","\n","        mask = df_imputed['education_composite'].isnull() & df_imputed['edlevel'].notna()\n","        df_imputed.loc[mask, 'education_composite'] = df_imputed.loc[mask, 'edlevel'].map(\n","            lambda x: edlevel_to_years.get(x, np.nan)\n","        )\n","\n","    # ============================================================\n","    # STEP 2: CREATE HOUSEHOLD-LEVEL AGGREGATES FOR IMPUTATION\n","    # ============================================================\n","    print(\"\\n2. CREATING HOUSEHOLD-LEVEL AGGREGATES\")\n","\n","    if 'hhid' in df_imputed.columns:\n","        household_col = 'hhid'\n","    else:\n","        df_imputed['household_id'] = df_imputed['individual_id'].astype(str).str[:-2]\n","        household_col = 'household_id'\n","\n","    # First, convert categorical education to numeric if needed\n","    if 'edlevel' in df_imputed.columns and df_imputed['edlevel'].dtype == 'object':\n","        edlevel_mapping = {\n","            'No education/preschool': 0,\n","            'No education': 0,\n","            'Preschool': 0,\n","            'Primary': 1,\n","            'Primary incomplete': 1,\n","            'Primary complete': 1,\n","            'Secondary': 2,\n","            'Secondary incomplete': 2,\n","            'Secondary complete': 2,\n","            'Higher': 3,\n","            'Higher education': 3,\n","            'University': 3,\n","            'Tertiary': 3\n","        }\n","        df_imputed['edlevel_numeric'] = df_imputed['edlevel'].map(edlevel_mapping)\n","    else:\n","        df_imputed['edlevel_numeric'] = pd.to_numeric(df_imputed['edlevel'], errors='coerce')\n","\n","    # Create household aggregates with appropriate functions for each variable type\n","    household_aggs = {}\n","\n","    # Numeric variables - use median\n","    for var in ['wealth', 'hhsize']:\n","        if var in df_imputed.columns:\n","            # Convert to numeric first to be safe\n","            df_imputed[var] = pd.to_numeric(df_imputed[var], errors='coerce')\n","            household_aggs[var] = 'median'\n","\n","    # Education - use numeric version\n","    if 'edlevel_numeric' in df_imputed.columns:\n","        household_aggs['edlevel_numeric'] = 'median'\n","\n","    # Geographic variables - use first (they should be same within household)\n","    for var in ['latitude', 'longitude']:\n","        if var in df_imputed.columns:\n","            df_imputed[var] = pd.to_numeric(df_imputed[var], errors='coerce')\n","            household_aggs[var] = 'first'\n","\n","    if household_aggs:\n","        household_stats = df_imputed.groupby([household_col, 'year']).agg(household_aggs).reset_index()\n","        household_stats.columns = [household_col, 'year'] + [f'hh_{col}' for col in household_stats.columns[2:]]\n","\n","        df_imputed = df_imputed.merge(household_stats, on=[household_col, 'year'], how='left')\n","\n","    for var in ['wealth', 'latitude', 'longitude']:\n","        if var in df_imputed.columns and f'hh_{var}' in df_imputed.columns:\n","            before = df_imputed[var].isnull().sum()\n","            df_imputed[var] = df_imputed[var].fillna(df_imputed[f'hh_{var}'])\n","            after = df_imputed[var].isnull().sum()\n","            print(f\"   {var}: filled {before - after} values using household averages\")\n","\n","    # For education, use the household numeric value to fill missing edlevel_numeric\n","    if 'edlevel_numeric' in df_imputed.columns and 'hh_edlevel_numeric' in df_imputed.columns:\n","        before = df_imputed['edlevel_numeric'].isnull().sum()\n","        df_imputed['edlevel_numeric'] = df_imputed['edlevel_numeric'].fillna(df_imputed['hh_edlevel_numeric'])\n","        after = df_imputed['edlevel_numeric'].isnull().sum()\n","        print(f\"   edlevel: filled {before - after} values using household median\")\n","\n","        # Also update the original edlevel if it exists\n","        if 'edlevel' in df_imputed.columns and df_imputed['edlevel'].dtype == 'object':\n","            # Map numeric back to categorical for missing edlevel values\n","            reverse_mapping = {0: 'No education', 1: 'Primary', 2: 'Secondary', 3: 'Higher'}\n","            mask = df_imputed['edlevel'].isnull() & df_imputed['edlevel_numeric'].notna()\n","            df_imputed.loc[mask, 'edlevel'] = df_imputed.loc[mask, 'edlevel_numeric'].round().map(reverse_mapping)\n","\n","    # For household size, use household median\n","    if 'hhsize' in df_imputed.columns and 'hh_hhsize' in df_imputed.columns:\n","        before = df_imputed['hhsize'].isnull().sum()\n","        df_imputed['hhsize'] = df_imputed['hhsize'].fillna(df_imputed['hh_hhsize'])\n","        after = df_imputed['hhsize'].isnull().sum()\n","        print(f\"   hhsize: filled {before - after} values using household median\")\n","\n","    # ============================================================\n","    # STEP 3: ASSET-BASED WEALTH IMPUTATION\n","    # ============================================================\n","    print(\"\\n3. ASSET-BASED WEALTH IMPUTATION\")\n","\n","    asset_vars = ['electrc_gh', 'radio_gh', 'tv_gh', 'pc_gh', 'bike_gh',\n","                  'car_gh', 'motorcycle_gh', 'fridge_gh', 'mobphone_gh']\n","    available_assets = [var for var in asset_vars if var in df_imputed.columns]\n","\n","    if available_assets and 'wealth' in df_imputed.columns:\n","        print(f\"   Using {len(available_assets)} asset variables\")\n","\n","        df_imputed['asset_count'] = df_imputed[available_assets].sum(axis=1)\n","\n","        has_assets = df_imputed['asset_count'].notna() & (df_imputed['asset_count'] > 0)\n","        missing_wealth = df_imputed['wealth'].isnull()\n","\n","        if (has_assets & ~missing_wealth).sum() > 100:\n","            train_data = df_imputed[has_assets & ~missing_wealth]\n","            wealth_by_assets = train_data.groupby('asset_count')['wealth'].median()\n","\n","            mask = has_assets & missing_wealth\n","            before = df_imputed['wealth'].isnull().sum()\n","            df_imputed.loc[mask, 'wealth'] = df_imputed.loc[mask, 'asset_count'].map(wealth_by_assets)\n","            after = df_imputed['wealth'].isnull().sum()\n","            print(f\"   Imputed {before - after} wealth values using asset ownership\")\n","\n","    # ============================================================\n","    # STEP 4: TIME-BASED INTERPOLATION\n","    # ============================================================\n","    print(\"\\n4. TIME-BASED INTERPOLATION FOR PANEL DATA\")\n","\n","    smooth_vars = ['age', 'edyears', 'education_composite', 'hhsize']\n","\n","    for var in smooth_vars:\n","        if var in df_imputed.columns:\n","            before = df_imputed[var].isnull().sum()\n","\n","            df_imputed[var] = df_imputed.groupby('individual_id')[var].transform(\n","                lambda x: x.interpolate(method='linear', limit_direction='both')\n","            )\n","\n","            after = df_imputed[var].isnull().sum()\n","            if before > after:\n","                print(f\"   {var}: interpolated {before - after} values\")\n","\n","    # ============================================================\n","    # STEP 5: KNN IMPUTATION FOR REMAINING MISSINGS\n","    # ============================================================\n","    print(\"\\n5. K-NEAREST NEIGHBORS IMPUTATION\")\n","\n","    knn_features = []\n","    potential_features = ['age', 'wealth', 'hhsize', 'education_composite',\n","                          'urban_combined', 'asset_count']\n","\n","    for feat in potential_features:\n","        if feat in df_imputed.columns and df_imputed[feat].notna().sum() > 100:\n","            knn_features.append(feat)\n","\n","    if len(knn_features) >= 3:\n","        print(f\"   Using features: {', '.join(knn_features)}\")\n","\n","        knn_data = df_imputed[knn_features].copy()\n","\n","        for col in knn_features:\n","            if knn_data[col].isnull().sum() / len(knn_data) < 0.5:\n","                imputer = KNNImputer(n_neighbors=5, weights='distance')\n","                knn_imputed = imputer.fit_transform(knn_data)\n","\n","                for i, col in enumerate(knn_features):\n","                    before = df_imputed[col].isnull().sum()\n","                    df_imputed[col] = knn_imputed[:, i]\n","                    after = df_imputed[col].isnull().sum()\n","                    if before > after:\n","                        print(f\"   {col}: KNN imputed {before - after} values\")\n","\n","    # ============================================================\n","    # STEP 6: MICE (MULTIPLE IMPUTATION BY CHAINED EQUATIONS)\n","    # ============================================================\n","    print(\"\\n6. MULTIPLE IMPUTATION BY CHAINED EQUATIONS (MICE)\")\n","\n","    mice_vars = ['wealth', 'edlevel', 'hhsize']\n","    available_mice_vars = [v for v in mice_vars if v in df_imputed.columns]\n","\n","    if available_mice_vars:\n","        mice_data = df_imputed[available_mice_vars].copy()\n","\n","        complete_rows = mice_data.dropna().shape[0]\n","        if complete_rows > 100:\n","            try:\n","                imputer = IterativeImputer(random_state=42, max_iter=10)\n","                mice_imputed = imputer.fit_transform(mice_data)\n","\n","                for i, col in enumerate(available_mice_vars):\n","                    before = df_imputed[col].isnull().sum()\n","                    mask = df_imputed[col].isnull()\n","                    df_imputed.loc[mask, col] = mice_imputed[mask, i]\n","                    after = df_imputed[col].isnull().sum()\n","                    if before > after:\n","                        print(f\"   {col}: MICE imputed {before - after} values\")\n","            except Exception as e:\n","                print(f\"   MICE failed: {str(e)[:50]}\")\n","\n","    # ============================================================\n","    # STEP 7: DISTRICT-LEVEL IMPUTATION FOR GEOGRAPHIC VARIABLES\n","    # ============================================================\n","    print(\"\\n7. GEOGRAPHIC CLUSTERING IMPUTATION\")\n","\n","    if 'district_cluster' in df_imputed.columns:\n","        district_stats = df_imputed.groupby(['district_cluster', 'year']).agg({\n","            'latitude': 'median',\n","            'longitude': 'median',\n","            'wealth': 'median',\n","            'urban_combined': lambda x: x.mode()[0] if len(x.mode()) > 0 else np.nan\n","        }).reset_index()\n","\n","        for var in ['latitude', 'longitude']:\n","            if var in df_imputed.columns:\n","                before = df_imputed[var].isnull().sum()\n","\n","                merge_cols = ['district_cluster', 'year']\n","                temp_merge = df_imputed[merge_cols + [var]].merge(\n","                    district_stats[merge_cols + [var]],\n","                    on=merge_cols,\n","                    how='left',\n","                    suffixes=('', '_district')\n","                )\n","\n","                df_imputed[var] = df_imputed[var].fillna(temp_merge[f'{var}_district'])\n","                after = df_imputed[var].isnull().sum()\n","                if before > after:\n","                    print(f\"   {var}: filled {before - after} using district medians\")\n","\n","    # ============================================================\n","    # STEP 8: LOGICAL RULES AND CONSTRAINTS\n","    # ============================================================\n","    print(\"\\n8. APPLYING LOGICAL CONSTRAINTS\")\n","\n","    df_imputed = df_imputed.sort_values(['individual_id', 'year'])\n","    df_imputed['age_expected'] = df_imputed.groupby('individual_id')['year'].transform(\n","        lambda x: x - x.iloc[0]\n","    ) + df_imputed.groupby('individual_id')['age'].transform('first')\n","\n","    mask = df_imputed['age'].isnull() & df_imputed['age_expected'].notna()\n","    df_imputed.loc[mask, 'age'] = df_imputed.loc[mask, 'age_expected']\n","\n","    df_imputed['edlevel'] = df_imputed.groupby('individual_id')['edlevel'].transform(\n","        lambda x: x.fillna(method='ffill')\n","    )\n","\n","    # ============================================================\n","    # STEP 9: TRADITIONAL PANEL IMPUTATION (FALLBACK)\n","    # ============================================================\n","    print(\"\\n9. TRADITIONAL PANEL IMPUTATION (FALLBACK)\")\n","\n","    for var in ['sex', 'edlevel', 'edlevel_numeric', 'wealth', 'hhsize', 'age']:\n","        if var in df_imputed.columns and df_imputed[var].isnull().any():\n","            before_count = df_imputed[var].isnull().sum()\n","\n","            if var in ['sex', 'edlevel']:\n","                # Use mode within individual for categorical variables\n","                mode_by_individual = df_imputed.groupby('individual_id')[var].transform(\n","                    lambda x: x.fillna(x.mode()[0]) if len(x.mode()) > 0 else x\n","                )\n","                df_imputed[var] = mode_by_individual\n","            else:\n","                # Forward/backward fill for numeric variables\n","                df_imputed[var] = df_imputed.groupby('individual_id')[var].transform(\n","                    lambda x: x.fillna(method='ffill').fillna(method='bfill')\n","                )\n","\n","            after_count = df_imputed[var].isnull().sum()\n","            if before_count > after_count:\n","                print(f\"   {var}: imputed {before_count - after_count} additional values\")\n","\n","    # Ensure consistency between edlevel and edlevel_numeric\n","    if 'edlevel' in df_imputed.columns and 'edlevel_numeric' in df_imputed.columns:\n","        # Use edlevel_numeric as primary (already numeric and imputed)\n","        # Update original edlevel for any remaining missing values\n","        if df_imputed['edlevel'].dtype == 'object':\n","            reverse_mapping = {0: 'No education', 1: 'Primary', 2: 'Secondary', 3: 'Higher'}\n","            mask = df_imputed['edlevel'].isnull() & df_imputed['edlevel_numeric'].notna()\n","            df_imputed.loc[mask, 'edlevel'] = df_imputed.loc[mask, 'edlevel_numeric'].round().map(reverse_mapping)\n","\n","    # ============================================================\n","    # FINAL SUMMARY\n","    # ============================================================\n","    print(\"\\n\" + \"=\"*60)\n","    print(\"IMPUTATION SUMMARY\")\n","    print(\"=\"*60)\n","\n","    # Use edlevel_numeric if we created it, otherwise use edlevel\n","    analysis_vars = ['sex', 'wealth', 'hhsize', 'age', 'latitude', 'longitude']\n","    if 'edlevel_numeric' in df_imputed.columns:\n","        analysis_vars.insert(1, 'edlevel_numeric')\n","    elif 'edlevel' in df_imputed.columns:\n","        analysis_vars.insert(1, 'edlevel')\n","\n","    print(\"\\nFinal missing values in key variables:\")\n","    total_missing = 0\n","    for var in analysis_vars:\n","        if var in df_imputed.columns:\n","            missing = df_imputed[var].isnull().sum()\n","            total_missing += missing\n","            if missing > 0:\n","                pct = 100 * missing / len(df_imputed)\n","                print(f\"  {var:15s}: {missing:8,} ({pct:5.1f}%)\")\n","\n","    if total_missing == 0:\n","        print(\"  ✓ All key variables successfully imputed!\")\n","\n","    complete_cases = df_imputed.dropna(subset=[v for v in analysis_vars if v in df_imputed.columns]).shape[0]\n","    print(f\"\\nComplete cases: {complete_cases:,} ({100*complete_cases/len(df_imputed):.1f}%)\")\n","\n","    # Drop temporary columns\n","    temp_cols = [col for col in df_imputed.columns if col.startswith('hh_') or col == 'age_expected']\n","    df_imputed = df_imputed.drop(columns=temp_cols, errors='ignore')\n","\n","    return df_imputed\n","\n","# ============================================================================\n","# PART 3: COLLINEARITY DIAGNOSTICS\n","# ============================================================================\n","\n","def diagnose_collinearity(df):\n","    \"\"\"\n","    Diagnose potential collinearity issues.\n","    \"\"\"\n","    print(\"\\n\" + \"=\"*60)\n","    print(\"COLLINEARITY DIAGNOSTICS\")\n","    print(\"=\"*60)\n","\n","    print(\"\\n1. TREATMENT-TIME RELATIONSHIP (Crosstab)\")\n","    print(\"   If heavily skewed, treatment may be collinear with year dummies:\")\n","    crosstab = pd.crosstab(df['within_10km'], df['year'], margins=True)\n","    print(crosstab)\n","\n","    print(\"\\n2. CORRELATION BETWEEN TREATMENT AND TIME INDICATORS\")\n","    for year in sorted(df['year'].unique()):\n","        if year != min(df['year'].unique()):\n","            year_dummy = (df['year'] == year).astype(int)\n","            corr = df['within_10km'].corr(year_dummy)\n","            print(f\"   within_10km vs year_{year}: r = {corr:.4f}\")\n","\n","    print(\"\\n3. CONDITION NUMBER (Simplified Check)\")\n","    print(\"   Creating model matrix for inspection...\")\n","    try:\n","        X = pd.get_dummies(df[['within_10km', 'post_rana', 'year']],\n","                           columns=['year'], drop_first=True)\n","        print(f\"   Number of columns: {X.shape[1]}\")\n","        condition_num = np.linalg.cond(X.values)\n","        print(f\"   Condition number: {condition_num:.2f}\")\n","        if condition_num > 30:\n","            print(\"   WARNING: High condition number suggests potential collinearity!\")\n","        else:\n","            print(\"   No collinearity issues detected\")\n","    except Exception as e:\n","        print(f\"   Check failed: {str(e)[:100]}\")\n","\n","# ============================================================================\n","# PART 4: EVENT STUDY\n","# ============================================================================\n","\n","def event_study_with_pretrends(df, treatment_var='within_10km'):\n","    \"\"\"\n","    Event study analysis with pre-trend tests.\n","    \"\"\"\n","    print(\"\\n\" + \"=\"*60)\n","    print(\"EVENT STUDY WITH PRE-TREND ANALYSIS\")\n","    print(\"=\"*60)\n","\n","    required_cols = [treatment_var, 'post_rana', 'year', 'child_labor', 'individual_id']\n","    if not all(col in df.columns for col in required_cols):\n","        print(f\"Error: Missing required columns\")\n","        return None, None\n","\n","    years = sorted(df['year'].unique())\n","    base_year = 2012 if 2012 in years else min(years)\n","\n","    year_terms = []\n","    interaction_terms = []\n","\n","    for year in years:\n","        rel_time = year - 2013\n","        if rel_time != -1:\n","            year_col_name = f'year_{year}'\n","            interaction_col_name = f'treat_X_year_{year}'\n","\n","            df[year_col_name] = (df['year'] == year).astype(int)\n","            year_terms.append(year_col_name)\n","\n","            df[interaction_col_name] = df[treatment_var] * df[year_col_name]\n","            interaction_terms.append(interaction_col_name)\n","\n","    print(f\"\\nRunning event study regression...\")\n","\n","    try:\n","        formula = f\"child_labor ~ {treatment_var} + {' + '.join(year_terms)} + {' + '.join(interaction_terms)}\"\n","        model = smf.ols(formula, data=df).fit(\n","            cov_type='cluster',\n","            cov_kwds={'groups': df['individual_id']}\n","        )\n","\n","        results = []\n","        for year in years:\n","            if year == base_year:\n","                coef, se = 0, 0\n","            else:\n","                param_name = f'treat_X_year_{year}'\n","                if param_name in model.params.index:\n","                    coef = model.params[param_name]\n","                    se = model.bse[param_name]\n","                else:\n","                    coef, se = np.nan, np.nan\n","\n","            results.append({\n","                'year': year,\n","                'rel_time': year - 2013,\n","                'coef': coef,\n","                'se': se,\n","            })\n","\n","        results_df = pd.DataFrame(results).dropna(subset=['coef'])\n","\n","        # Pre-trend test\n","        pre_period = results_df[results_df['rel_time'] < 0]\n","        if len(pre_period) >= 2:\n","            try:\n","                trend_model = smf.ols('coef ~ rel_time', data=pre_period).fit()\n","                pre_trend_pval = trend_model.pvalues['rel_time']\n","                print(f\"\\nPre-trend test:\")\n","                print(f\"  Slope: {trend_model.params['rel_time']:.6f}\")\n","                print(f\"  P-value: {pre_trend_pval:.4f}\")\n","                if pre_trend_pval < 0.05:\n","                    print(\"  WARNING: Significant pre-trend detected!\")\n","                else:\n","                    print(\"  No significant pre-trend\")\n","            except:\n","                pass\n","\n","        # Plot\n","        fig, ax = plt.subplots(figsize=(12, 6))\n","        ax.errorbar(results_df['rel_time'], results_df['coef'],\n","                   yerr=1.96*results_df['se'],\n","                   marker='o', capsize=5, capthick=2, markersize=8, linewidth=2)\n","        ax.axhline(y=0, color='black', linestyle='-', alpha=0.3)\n","        ax.axvline(x=0, color='red', linestyle='--', alpha=0.5, label='Rana Plaza (2013)', linewidth=2)\n","        ax.set_xlabel('Years Relative to Rana Plaza', fontsize=12)\n","        ax.set_ylabel('Coefficient', fontsize=12)\n","        ax.set_title('Event Study: Dynamic Treatment Effects', fontsize=14, fontweight='bold')\n","        ax.grid(True, alpha=0.3)\n","        ax.legend()\n","        plt.tight_layout()\n","        plt.savefig('event_study_enhanced.png', dpi=300, bbox_inches='tight')\n","        print(f\"\\nEvent study plot saved as 'event_study_enhanced.png'\")\n","\n","        return model, results_df\n","\n","    except Exception as e:\n","        print(f\"Error in event study: {e}\")\n","        return None, None\n","\n","# ============================================================================\n","# PART 5: MAIN SPECIFICATIONS WITH SENSITIVITY ANALYSIS\n","# ============================================================================\n","\n","def run_main_specifications_with_diagnostics(df):\n","    \"\"\"\n","    Main DID specifications with controls sensitivity analysis.\n","    \"\"\"\n","    print(\"\\n\" + \"=\"*60)\n","    print(\"MAIN DIFFERENCE-IN-DIFFERENCES SPECIFICATIONS\")\n","    print(\"=\"*60)\n","\n","    results = {}\n","    df['treat_X_post'] = df['within_10km'] * df['post_rana']\n","\n","    # 1. BASIC DID\n","    print(\"\\n1. BASIC DID (within 10km)\")\n","    try:\n","        model_basic = smf.ols('child_labor ~ within_10km + post_rana + treat_X_post + C(year)',\n","                              data=df).fit(cov_type='cluster',\n","                                          cov_kwds={'groups': df['individual_id']})\n","        print(f\"   Coefficient: {model_basic.params['treat_X_post']:.6f}\")\n","        print(f\"   SE: {model_basic.bse['treat_X_post']:.6f}\")\n","        print(f\"   P-value: {model_basic.pvalues['treat_X_post']:.6f}\")\n","        if model_basic.bse['treat_X_post'] > 1:\n","            print(\"   WARNING: Very large SE suggests numerical instability\")\n","        results['basic'] = model_basic\n","    except Exception as e:\n","        print(f\"   Failed: {e}\")\n","        results['basic'] = None\n","\n","    # 2. WITH TRENDS\n","    print(\"\\n2. DID WITH LINEAR TRENDS\")\n","    if 'year_linear' not in df.columns:\n","        df['year_linear'] = df['year'] - df['year'].min()\n","    df['treat_X_trend'] = df['within_10km'] * df['year_linear']\n","\n","    try:\n","        model_trends = smf.ols('child_labor ~ within_10km + post_rana + treat_X_post + '\n","                               'year_linear + treat_X_trend + C(year)',\n","                               data=df).fit(cov_type='cluster',\n","                                           cov_kwds={'groups': df['individual_id']})\n","        print(f\"   Coefficient: {model_trends.params['treat_X_post']:.6f}\")\n","        print(f\"   P-value: {model_trends.pvalues['treat_X_post']:.6f}\")\n","        results['trends'] = model_trends\n","    except Exception as e:\n","        print(f\"   Failed: {e}\")\n","        results['trends'] = None\n","\n","    # 3. WITH CONTROLS - FULL SET\n","    print(\"\\n3. DID WITH FULL CONTROLS (sex, education, wealth, household size)\")\n","    control_cols = ['sex', 'edlevel', 'wealth', 'hhsize']\n","\n","    # Check if we have numeric version of edlevel\n","    if 'edlevel_numeric' in df.columns:\n","        control_cols = ['sex', 'edlevel_numeric', 'wealth', 'hhsize']\n","\n","    available_controls = [col for col in control_cols if col in df.columns and not df[col].isnull().all()]\n","\n","    if available_controls:\n","        df_full = df.dropna(subset=available_controls + ['child_labor']).copy()\n","        df_full['treat_X_post'] = df_full['within_10km'] * df_full['post_rana']\n","\n","        try:\n","            formula_full = f\"child_labor ~ within_10km + post_rana + treat_X_post + C(year)\"\n","            for var in available_controls:\n","                # Treat sex and the original edlevel as categorical\n","                if var in ['sex', 'edlevel'] and df_full[var].dtype == 'object':\n","                    formula_full += f\" + C({var})\"\n","                else:\n","                    # Treat numeric variables (including edlevel_numeric) as continuous\n","                    formula_full += f\" + {var}\"\n","\n","            model_full = smf.ols(formula_full, data=df_full).fit(\n","                cov_type='cluster',\n","                cov_kwds={'groups': df_full['individual_id']}\n","            )\n","\n","            print(f\"   Sample: {len(df_full):,} (from {len(df):,})\")\n","            print(f\"   Coefficient: {model_full.params['treat_X_post']:.6f}\")\n","            print(f\"   SE: {model_full.bse['treat_X_post']:.6f}\")\n","            print(f\"   P-value: {model_full.pvalues['treat_X_post']:.6f}\")\n","            results['controls_full'] = model_full\n","        except Exception as e:\n","            print(f\"   Failed: {e}\")\n","            results['controls_full'] = None\n","\n","    # 4. SENSITIVITY: REMOVE CONTROLS ONE BY ONE\n","    print(\"\\n4. SENSITIVITY ANALYSIS: REMOVING CONTROLS ONE BY ONE\")\n","\n","    if available_controls and 'controls_full' in results and results['controls_full']:\n","        base_coef = results['controls_full'].params['treat_X_post']\n","        base_pval = results['controls_full'].pvalues['treat_X_post']\n","        print(f\"   Base (all controls): coef={base_coef:.6f}, p={base_pval:.6f}\")\n","\n","        for exclude_var in available_controls:\n","            remaining = [v for v in available_controls if v != exclude_var]\n","            try:\n","                formula_test = f\"child_labor ~ within_10km + post_rana + treat_X_post + C(year)\"\n","                for var in remaining:\n","                    if var in ['sex', 'edlevel']:\n","                        formula_test += f\" + C({var})\"\n","                    else:\n","                        formula_test += f\" + {var}\"\n","\n","                model_test = smf.ols(formula_test, data=df_full).fit(\n","                    cov_type='cluster',\n","                    cov_kwds={'groups': df_full['individual_id']}\n","                )\n","\n","                coef_change = model_test.params['treat_X_post'] - base_coef\n","                pval_test = model_test.pvalues['treat_X_post']\n","                print(f\"   Without {exclude_var:10s}: coef={model_test.params['treat_X_post']:.6f}, \" +\n","                      f\"p={pval_test:.6f}, Δcoef={coef_change:+.6f}\")\n","            except Exception as e:\n","                print(f\"   Without {exclude_var:10s}: Failed\")\n","\n","    # 5. ALTERNATIVE CLUSTERING BY DISTRICT\n","    print(\"\\n5. ROBUSTNESS: ALTERNATIVE CLUSTERING (by district/cluster)\")\n","    if 'district_cluster' in df.columns and 'controls_full' in results and results['controls_full']:\n","        try:\n","            model_district = smf.ols(formula_full, data=df_full).fit(\n","                cov_type='cluster',\n","                cov_kwds={'groups': df_full['district_cluster']}\n","            )\n","\n","            print(f\"   Coefficient: {model_district.params['treat_X_post']:.6f}\")\n","            print(f\"   SE: {model_district.bse['treat_X_post']:.6f}\")\n","            print(f\"   P-value: {model_district.pvalues['treat_X_post']:.6f}\")\n","            results['controls_district_cluster'] = model_district\n","        except Exception as e:\n","            print(f\"   Failed: {e}\")\n","\n","    # 6. ALTERNATIVE DISTANCE THRESHOLDS\n","    print(\"\\n6. ROBUSTNESS: ALTERNATIVE DISTANCE THRESHOLDS\")\n","    for threshold in [5, 15, 20]:\n","        if f'within_{threshold}km' in df.columns:\n","            df[f'treat_{threshold}_X_post'] = df[f'within_{threshold}km'] * df['post_rana']\n","            try:\n","                model_thresh = smf.ols(f'child_labor ~ within_{threshold}km + post_rana + '\n","                                      f'treat_{threshold}_X_post + C(year)',\n","                                      data=df).fit(cov_type='cluster',\n","                                                  cov_kwds={'groups': df['individual_id']})\n","                print(f\"   {threshold}km threshold: coef={model_thresh.params[f'treat_{threshold}_X_post']:.6f}, \"\n","                      f\"p={model_thresh.pvalues[f'treat_{threshold}_X_post']:.6f}\")\n","                results[f'threshold_{threshold}km'] = model_thresh\n","            except:\n","                print(f\"   {threshold}km threshold: Failed\")\n","\n","    return results\n","\n","# ============================================================================\n","# PART 6: PLACEBO TESTS\n","# ============================================================================\n","\n","def improved_placebo_tests(df):\n","    \"\"\"\n","    Comprehensive placebo tests for validity.\n","    \"\"\"\n","    print(\"\\n\" + \"=\"*60)\n","    print(\"PLACEBO TESTS\")\n","    print(\"=\"*60)\n","\n","    # 1. Random treatment assignment\n","    print(\"\\n1. RANDOMIZED TREATMENT ASSIGNMENT\")\n","    np.random.seed(42)\n","    placebo_coefs = []\n","    df_placebo = df.copy()\n","\n","    for i in range(100):\n","        df_placebo['placebo_treat'] = np.random.permutation(df_placebo['within_10km'].values)\n","        df_placebo['placebo_X_post'] = df_placebo['placebo_treat'] * df_placebo['post_rana']\n","        try:\n","            model = smf.ols('child_labor ~ placebo_treat + post_rana + placebo_X_post + C(year)',\n","                           data=df_placebo).fit()\n","            placebo_coefs.append(model.params['placebo_X_post'])\n","        except:\n","            pass\n","\n","    if placebo_coefs:\n","        print(f\"   Mean coefficient: {np.mean(placebo_coefs):.6f}\")\n","        print(f\"   Std deviation: {np.std(placebo_coefs):.6f}\")\n","        print(f\"   95% CI: [{np.percentile(placebo_coefs, 2.5):.6f}, {np.percentile(placebo_coefs, 97.5):.6f}]\")\n","        print(\"   (Should be centered around zero)\")\n","\n","    # 2. False treatment years\n","    print(\"\\n2. FALSE TREATMENT YEARS (Pre-period only)\")\n","    df_pre = df[df['post_rana'] == 0].copy()\n","    pre_years = sorted(df_pre['year'].unique())\n","\n","    if len(pre_years) >= 3:\n","        fake_year = pre_years[-2]\n","        df_pre['fake_post'] = (df_pre['year'] > fake_year).astype(int)\n","        df_pre['treat_X_fake'] = df_pre['within_10km'] * df_pre['fake_post']\n","\n","        try:\n","            model_fake = smf.ols('child_labor ~ within_10km + fake_post + treat_X_fake + C(year)',\n","                                data=df_pre).fit(cov_type='cluster',\n","                                                cov_kwds={'groups': df_pre['individual_id']})\n","            print(f\"   Fake treatment year {fake_year}:\")\n","            print(f\"   Coefficient: {model_fake.params['treat_X_fake']:.6f}\")\n","            print(f\"   P-value: {model_fake.pvalues['treat_X_fake']:.6f}\")\n","            print(\"   (Should be non-significant)\")\n","        except Exception as e:\n","            print(f\"   Failed: {e}\")\n","\n","    # 3. Placebo outcome\n","    print(\"\\n3. PLACEBO OUTCOME (Non-child labor variable)\")\n","    if 'sex' in df.columns:\n","        df_placebo = df.copy()\n","        df_placebo['female'] = (df_placebo['sex'] == 'Female').astype(int)\n","        df_placebo['treat_X_post'] = df_placebo['within_10km'] * df_placebo['post_rana']\n","\n","        try:\n","            model_placebo_outcome = smf.ols('female ~ within_10km + post_rana + treat_X_post + C(year)',\n","                                           data=df_placebo).fit()\n","            print(f\"   Effect on gender (should be zero):\")\n","            print(f\"   Coefficient: {model_placebo_outcome.params['treat_X_post']:.6f}\")\n","            print(f\"   P-value: {model_placebo_outcome.pvalues['treat_X_post']:.6f}\")\n","        except:\n","            print(\"   Failed to run placebo outcome test\")\n","\n","# ============================================================================\n","# PART 7: HETEROGENEITY ANALYSIS\n","# ============================================================================\n","\n","def heterogeneity_analysis(df):\n","    \"\"\"\n","    Heterogeneous effects analysis across subgroups.\n","    \"\"\"\n","    print(\"\\n\" + \"=\"*60)\n","    print(\"HETEROGENEITY ANALYSIS\")\n","    print(\"=\"*60)\n","\n","    results = []\n","    df['treat_X_post'] = df['within_10km'] * df['post_rana']\n","\n","    # Age groups\n","    print(\"\\n1. BY AGE GROUP:\")\n","    if 'age_group' in df.columns:\n","        for age_group in ['5-9', '10-13', '14-17']:\n","            df_age = df[df['age_group'] == age_group].copy()\n","            if len(df_age) > 100:\n","                try:\n","                    model = smf.ols('child_labor ~ within_10km + post_rana + treat_X_post + C(year)',\n","                                   data=df_age).fit(cov_type='cluster',\n","                                                   cov_kwds={'groups': df_age['individual_id']})\n","                    results.append({\n","                        'Subgroup': f'Age {age_group}',\n","                        'Coef': model.params['treat_X_post'],\n","                        'SE': model.bse['treat_X_post'],\n","                        'P_Value': model.pvalues['treat_X_post'],\n","                        'N': len(df_age)\n","                    })\n","                    print(f\"  {age_group}: coef={model.params['treat_X_post']:.6f}, \"\n","                          f\"p={model.pvalues['treat_X_post']:.4f}, N={len(df_age):,}\")\n","                except Exception as e:\n","                    print(f\"  {age_group}: Failed - {str(e)[:50]}\")\n","\n","    # Gender\n","    print(\"\\n2. BY GENDER:\")\n","    if 'sex' in df.columns:\n","        for gender in df['sex'].dropna().unique():\n","            df_gender = df[df['sex'] == gender].copy()\n","            if len(df_gender) > 100:\n","                try:\n","                    model = smf.ols('child_labor ~ within_10km + post_rana + treat_X_post + C(year)',\n","                                   data=df_gender).fit(cov_type='cluster',\n","                                                      cov_kwds={'groups': df_gender['individual_id']})\n","                    results.append({\n","                        'Subgroup': str(gender),\n","                        'Coef': model.params['treat_X_post'],\n","                        'SE': model.bse['treat_X_post'],\n","                        'P_Value': model.pvalues['treat_X_post'],\n","                        'N': len(df_gender)\n","                    })\n","                    print(f\"  {gender}: coef={model.params['treat_X_post']:.6f}, \"\n","                          f\"p={model.pvalues['treat_X_post']:.4f}, N={len(df_gender):,}\")\n","                except:\n","                    print(f\"  {gender}: Failed\")\n","\n","    # Wealth quintiles\n","    print(\"\\n3. BY WEALTH QUINTILE:\")\n","    if 'wealth' in df.columns and df['wealth'].notna().sum() > 0:\n","        df['wealth_quintile'] = pd.qcut(df['wealth'].dropna(), q=5, labels=['Q1', 'Q2', 'Q3', 'Q4', 'Q5'])\n","\n","        for quintile in ['Q1', 'Q2', 'Q3', 'Q4', 'Q5']:\n","            df_wealth = df[df['wealth_quintile'] == quintile].copy()\n","            if len(df_wealth) > 100:\n","                try:\n","                    model = smf.ols('child_labor ~ within_10km + post_rana + treat_X_post + C(year)',\n","                                   data=df_wealth).fit(cov_type='cluster',\n","                                                      cov_kwds={'groups': df_wealth['individual_id']})\n","                    results.append({\n","                        'Subgroup': f'Wealth {quintile}',\n","                        'Coef': model.params['treat_X_post'],\n","                        'SE': model.bse['treat_X_post'],\n","                        'P_Value': model.pvalues['treat_X_post'],\n","                        'N': len(df_wealth)\n","                    })\n","                    print(f\"  {quintile}: coef={model.params['treat_X_post']:.6f}, \"\n","                          f\"p={model.pvalues['treat_X_post']:.4f}, N={len(df_wealth):,}\")\n","                except:\n","                    print(f\"  {quintile}: Failed\")\n","\n","    # Urban vs Rural\n","    print(\"\\n4. BY URBAN/RURAL STATUS:\")\n","    if 'urban_combined' in df.columns or 'urbanhh' in df.columns:\n","        urban_col = 'urban_combined' if 'urban_combined' in df.columns else 'urbanhh'\n","\n","        for urban_status in df[urban_col].dropna().unique():\n","            df_urban = df[df[urban_col] == urban_status].copy()\n","            if len(df_urban) > 100:\n","                try:\n","                    model = smf.ols('child_labor ~ within_10km + post_rana + treat_X_post + C(year)',\n","                                   data=df_urban).fit(cov_type='cluster',\n","                                                     cov_kwds={'groups': df_urban['individual_id']})\n","                    status_label = 'Urban' if urban_status == 1 else 'Rural'\n","                    results.append({\n","                        'Subgroup': status_label,\n","                        'Coef': model.params['treat_X_post'],\n","                        'SE': model.bse['treat_X_post'],\n","                        'P_Value': model.pvalues['treat_X_post'],\n","                        'N': len(df_urban)\n","                    })\n","                    print(f\"  {status_label}: coef={model.params['treat_X_post']:.6f}, \"\n","                          f\"p={model.pvalues['treat_X_post']:.4f}, N={len(df_urban):,}\")\n","                except:\n","                    print(f\"  {status_label}: Failed\")\n","\n","    if results:\n","        het_df = pd.DataFrame(results)\n","        print(\"\\n\" + \"=\"*60)\n","        print(\"HETEROGENEITY RESULTS SUMMARY\")\n","        print(\"=\"*60)\n","        print(het_df.to_string())\n","\n","        # Create heterogeneity plot\n","        fig, ax = plt.subplots(figsize=(10, 6))\n","\n","        # Sort by coefficient\n","        het_df = het_df.sort_values('Coef')\n","\n","        # Plot coefficients with error bars\n","        positions = range(len(het_df))\n","        ax.errorbar(het_df['Coef'], positions,\n","           